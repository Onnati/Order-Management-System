# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=order_management
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
# Docker Compose:  postgresql://USER:PASS@db:5432/DBNAME
# Local backend:    postgresql://USER:PASS@localhost:5432/DBNAME
DATABASE_URL=postgresql://orderapp:orderapp_secret@db:5432/order_management
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Frontend (browser-accessible API URL)
VITE_API_URL=http://localhost:8000
